{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Grayslate",
  "mainBinaryName": "Grayslate",
  "version": "0.1.3",
  "identifier": "app.grayslate.Grayslate",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../build"
  },
  "app": {
    "windows": [
      {
        "create": false,
        "title": "Grayslate",
        "width": 800,
        "height": 600,
        "minWidth": 400,
        "minHeight": 300,
        "decorations": false,
        "theme": "Dark",
        "visible": false,
        "backgroundColor": [27, 30, 38, 255]
      }
    ],
    "security": {
      "capabilities": ["default"],
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob:; font-src 'self' data:; connect-src 'self' ipc: http://ipc.localhost; object-src 'none'; base-uri 'none'; form-action 'none'; frame-src 'none'; frame-ancestors 'none'; worker-src 'none'; media-src 'none'",
      "headers": {
        "X-Content-Type-Options": "nosniff"
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEZCMjNFNjBFOEQzMTQ1MQpSV1JSRk5Qb1lENnlEL3lsNDNxZ0VTRkJ3NHB3dGdlSXErMzlJMHZQaDkvUTU3L2twaGhpUGUzRAo=",
      "endpoints": [
        "https://github.com/shriram-ethiraj/grayslate/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}

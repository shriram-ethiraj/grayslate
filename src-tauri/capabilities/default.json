{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": [
    "main"
  ],
  "permissions": [
    "core:event:allow-emit",
    "core:event:allow-listen",
    "core:event:allow-unlisten",
    "core:window:allow-close",
    "core:window:allow-is-maximized",
    "core:window:allow-minimize",
    "core:window:allow-start-dragging",
    "core:window:allow-toggle-maximize",
    "clipboard-manager:allow-write-text",
    "os:allow-os-type",
    "allow-autosave-activate-document",
    "allow-autosave-activate-untitled",
    "allow-autosave-flush-before-switch",
    "allow-autosave-notify-changed",
    "allow-autosave-set-csv-mode",
    "allow-autosave-set-language-hint",
    "allow-autosave-submit-content",
    "allow-cancel-editor-find",
    "allow-cancel-file-read",
    "allow-cancel-markdown-preview",
    "allow-cancel-sidebar-search",
    "allow-cancel-transformation",
    "allow-check-for-updates",
    "allow-csv-cancel",
    "allow-csv-dispose",
    "allow-csv-flush-text",
    "allow-csv-get-cell",
    "allow-csv-get-rows",
    "allow-csv-initialize",
    "allow-csv-mutate",
    "allow-csv-redo",
    "allow-csv-undo",
    "allow-delete-file",
    "allow-detect-by-filename",
    "allow-detect-language",
    "allow-duplicate-file",
    "allow-duplicate-local-file-as-slate",
    "allow-editor-detect-indent",
    "allow-editor-find-scan",
    "allow-editor-find-selection",
    "allow-execute-transformation",
    "allow-get-all-settings",
    "allow-get-app-info",
    "allow-get-app-setting",
    "allow-get-last-active-document",
    "allow-get-memory-info",
    "allow-get-recent-files",
    "allow-install-available-update",
    "allow-open-about-link",
    "allow-open-markdown-link",
    "allow-pick-document",
    "allow-pick-notes-root",
    "allow-pick-save-document",
    "allow-read-file-content",
    "allow-read-markdown-preview-asset",
    "allow-rename-file",
    "allow-render-markdown-preview",
    "allow-reset-notes-root",
    "allow-resolve-default-notes-root",
    "allow-resolve-notes-root",
    "allow-reveal-document",
    "allow-save-untitled-slate",
    "allow-search-sidebar-files",
    "allow-set-app-setting",
    "allow-set-last-active-document",
    "allow-set-menu-save-enabled",
    "allow-set-menu-word-wrap",
    "allow-suggest-name-for-file",
    "allow-suggest-slate-name",
    "allow-untrack-local-file",
    "allow-write-file-content"
  ]
}

---
import { downloads, site } from "../lib/site";
import InstallCommand from "./InstallCommand.astro";
---

<section class="section download-section" id="download" itemscope itemtype="https://schema.org/SoftwareApplication">
  <meta itemprop="name" content="Grayslate" />
  <meta itemprop="applicationCategory" content="DeveloperApplication" />
  <meta itemprop="operatingSystem" content="macOS, Windows, Linux" />
  <div itemprop="offers" itemscope itemtype="https://schema.org/Offer">
    <meta itemprop="price" content="0" />
    <meta itemprop="priceCurrency" content="USD" />
  </div>
  <div class="container download-panel">
    <div class="download-heading">
      <p class="section-kicker">Ready when you are</p>
      <h2>Keep the small jobs out of your browser.</h2>
      <p>Install Grayslate and turn code, data, and quick notes into automatically saved, searchable slates.</p>
    </div>

    <div class="platform-grid">
      {downloads.map((download) => (
        <article
          class="platform-card"
          id={`download-${download.os}`}
          data-platform-download={download.os}
        >
          <div class="platform-card-header">
            <span class="platform-icon" aria-hidden="true">
              {download.os === "macos" && <svg viewBox="0 0 24 24"><path d="M16.7 12.8c0-2.8 2.3-4.2 2.4-4.3a5.2 5.2 0 0 0-4-2.2c-1.7-.2-3.3 1-4.2 1-.9 0-2.2-1-3.7-1A5.5 5.5 0 0 0 2.6 9c-2 3.4-.5 8.4 1.4 11.1 1 1.3 2.1 2.8 3.6 2.7 1.4-.1 2-1 3.7-1s2.2 1 3.7 1c1.5 0 2.5-1.4 3.4-2.7a12 12 0 0 0 1.6-3.3 4.9 4.9 0 0 1-3.3-4ZM14 4.5A4.9 4.9 0 0 0 15.2 1a5 5 0 0 0-3.3 1.7 4.6 4.6 0 0 0-1.2 3.4A4.2 4.2 0 0 0 14 4.5Z"></path></svg>}
              {download.os === "windows" && <svg viewBox="0 0 24 24"><path d="m3 5.6 7.3-1v7H3v-6Zm8.3-1.2L21 3v8.6h-9.7V4.4ZM3 12.6h7.3v7L3 18.5v-5.9Zm8.3 0H21V21l-9.7-1.4v-7Z"></path></svg>}
              {download.os === "linux" && <svg viewBox="0 0 24 24"><path d="M12 2c-3 0-4 2.4-4 5.4 0 1-.2 1.8-.6 2.5-.8 1.3-2.2 2.5-2.7 4.8-.3 1.3 0 2.4.7 3.2-.2.8 0 1.7.7 2.2.8.6 1.9.5 2.7-.1 1 .7 2 .9 3.2.9s2.2-.2 3.2-.9c.8.6 1.9.7 2.7.1.7-.5.9-1.4.7-2.2.7-.8 1-1.9.7-3.2-.5-2.3-1.9-3.5-2.7-4.8-.4-.7-.6-1.5-.6-2.5C16 4.4 15 2 12 2Z"></path><circle cx="10.5" cy="7" r=".7" fill="var(--background)" stroke="none"></circle><circle cx="13.5" cy="7" r=".7" fill="var(--background)" stroke="none"></circle><path d="M10 10c1.2.8 2.8.8 4 0M9 15c.8 1.1 1.8 1.7 3 1.7s2.2-.6 3-1.7"></path></svg>}
            </span>
            <span class="platform-copy">
              <span class="platform-title-row">
                <strong>{download.shortLabel}</strong>
                <span class="detected-os-badge" aria-hidden="true">Your OS</span>
              </span>
              <small>{download.architecture}</small>
            </span>
          </div>

          {download.installCommand && download.installPrimary && (
            <InstallCommand
              command={download.installCommand}
              label={download.installLabel ?? "Install command"}
              primary
            />
          )}

          <div class="platform-actions">
            <a
              class={download.installPrimary ? "platform-secondary" : "platform-primary"}
              href={download.href}
              itemprop="downloadUrl"
            >
              <span class="platform-action-copy">
                <span>Download {download.format}</span>
                <small>{download.downloadSubtitle}</small>
              </span>
              <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M12 4v12m0 0 4-4m-4 4-4-4M5 21h14"></path></svg>
            </a>
            {download.alternatives?.map((alternative) => (
              <a class="platform-secondary" href={alternative.href} itemprop="downloadUrl">
                <span class="platform-action-copy">
                  <span>Download {alternative.format}</span>
                  <small>{alternative.subtitle}</small>
                </span>
                <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M12 4v12m0 0 4-4m-4 4-4-4M5 21h14"></path></svg>
              </a>
            ))}
          </div>

          {download.installCommand && !download.installPrimary && (
            <InstallCommand
              command={download.installCommand}
              label={download.installLabel ?? "Install command"}
            />
          )}

          {download.os === "macos" && (
            <p class="platform-note">Ad-hoc signed; macOS may require Open Anyway on first launch.</p>
          )}
          {download.os === "linux" && (
            <p class="platform-note">Repository installs receive system updates. AppImage remains standalone. Packages currently target x86_64.</p>
          )}
        </article>
      ))}
    </div>

    <p class="other-downloads">
      Looking for another package or architecture? <a href={site.latestReleaseUrl}>View all downloads and release notes</a>.
    </p>
  </div>
</section>

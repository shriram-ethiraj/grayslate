---
import type { ImageMetadata } from "astro";
import { getImage } from "astro:assets";

interface Props {
  dark: ImageMetadata;
  light: ImageMetadata;
  alt: string;
  loading?: "eager" | "lazy";
  fetchpriority?: "high" | "low" | "auto";
  sizes?: string;
}

const {
  dark,
  light,
  alt,
  loading = "lazy",
  fetchpriority = "auto",
  sizes = "(max-width: 720px) calc(100vw - 2rem), (max-width: 1184px) calc(100vw - 3rem), 1120px",
} = Astro.props;

const widths = [480, 768, 1120, 1600, 2200].filter((width) => width <= dark.width);

async function createSrcSet(
  src: ImageMetadata,
  format: "avif" | "webp",
  quality: number,
) {
  const images = await Promise.all(
    widths.map((width) => getImage({ src, width, format, quality })),
  );

  return {
    src: images.find((_, index) => widths[index] === 1120)?.src ?? images.at(-1)!.src,
    srcset: images.map((image, index) => `${image.src} ${widths[index]}w`).join(", "),
  };
}

const [lightAvif, lightWebp, darkAvif, darkWebp] = await Promise.all([
  createSrcSet(light, "avif", 75),
  createSrcSet(light, "webp", 82),
  createSrcSet(dark, "avif", 75),
  createSrcSet(dark, "webp", 82),
]);
---

<picture class="theme-screenshot" data-theme-picture>
  <source
    data-theme-source="light"
    media="(prefers-color-scheme: light)"
    type="image/avif"
    srcset={lightAvif.srcset}
    sizes={sizes}
  />
  <source
    data-theme-source="light"
    media="(prefers-color-scheme: light)"
    type="image/webp"
    srcset={lightWebp.srcset}
    sizes={sizes}
  />
  <source
    type="image/avif"
    srcset={darkAvif.srcset}
    sizes={sizes}
  />
  <img
    src={darkWebp.src}
    srcset={darkWebp.srcset}
    sizes={sizes}
    alt={alt}
    width={dark.width}
    height={dark.height}
    loading={loading}
    decoding="async"
    fetchpriority={fetchpriority}
  />
</picture>

---
import Brand from "./Brand.astro";
import { site } from "../lib/site";
---

<header class="site-header" data-site-header>
  <div class="container nav-shell">
    <a class="brand-link" href="#top" aria-label="Grayslate home">
      <Brand compact />
    </a>

    <nav class="desktop-nav" aria-label="Primary navigation">
      <a href="#features">Features</a>
      <a href="#faq">FAQ</a>
    </nav>

    <div class="nav-actions">
      <a
        class="icon-button"
        href={site.repositoryUrl}
        aria-label="View Grayslate on GitHub"
        title="View on GitHub"
      >
        <svg viewBox="0 0 24 24" aria-hidden="true">
          <path d="M12 .7a11.5 11.5 0 0 0-3.64 22.4c.58.1.79-.25.79-.56v-2.23c-3.22.7-3.9-1.37-3.9-1.37-.53-1.34-1.29-1.7-1.29-1.7-1.05-.72.08-.71.08-.71 1.17.08 1.78 1.2 1.78 1.2 1.04 1.77 2.72 1.26 3.38.96.1-.75.4-1.26.74-1.55-2.57-.3-5.27-1.28-5.27-5.69 0-1.26.45-2.28 1.19-3.09-.12-.29-.52-1.46.11-3.05 0 0 .97-.31 3.16 1.18a10.9 10.9 0 0 1 5.75 0c2.2-1.49 3.16-1.18 3.16-1.18.63 1.59.23 2.76.11 3.05.74.81 1.19 1.83 1.19 3.09 0 4.42-2.7 5.39-5.28 5.68.42.36.79 1.06.79 2.14v3.17c0 .31.21.67.79.56A11.5 11.5 0 0 0 12 .7Z"></path>
        </svg>
      </a>

      <button class="icon-button" type="button" data-theme-toggle aria-label="Use light theme" title="Change theme">
        <svg class="theme-icon theme-icon--sun" viewBox="0 0 24 24" aria-hidden="true">
          <circle cx="12" cy="12" r="3.5"></circle>
          <path d="M12 1.75v2.5"></path>
          <path d="M12 19.75v2.5"></path>
          <path d="m4.75 4.75 1.8 1.8"></path>
          <path d="m17.45 17.45 1.8 1.8"></path>
          <path d="M1.75 12h2.5"></path>
          <path d="M19.75 12h2.5"></path>
          <path d="m4.75 19.25 1.8-1.8"></path>
          <path d="m17.45 6.55 1.8-1.8"></path>
        </svg>
        <svg class="theme-icon theme-icon--moon" viewBox="0 0 24 24" aria-hidden="true">
          <path d="M20.5 14.2A8.5 8.5 0 0 1 9.8 3.5a8.5 8.5 0 1 0 10.7 10.7Z"></path>
        </svg>
      </button>

      <a class="button button--small nav-download" href="#download">Download</a>
    </div>
  </div>
</header>

---
import "../styles/global.css";
import { site } from "../lib/site";

interface Props {
  title?: string;
  description?: string;
  image?: string;
}

const {
  title = site.title,
  description = site.description,
  image = "/og-grayslate.png",
} = Astro.props;
const canonical = new URL(Astro.url.pathname, site.url);
const socialImage = new URL(image, site.url);
---

<!doctype html>
<html lang="en" data-theme="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#1b1e26" />
    <meta name="color-scheme" content="light dark" />
    <link rel="canonical" href={canonical} />
    <link rel="icon" href="/favicon.png" type="image/png" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />

    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={site.name} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={socialImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="Grayslate developer scratchpad" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={socialImage} />

    <script is:inline src="/theme-init.js"></script>
    <title>{title}</title>
  </head>
  <body>
    <a class="skip-link" href="#main-content">Skip to content</a>
    <slot />
    <script is:inline type="module" src="/site.js"></script>
    <script is:inline defer src="https://static.cloudflareinsights.com/beacon.min.js"
      data-cf-beacon='{"token": "1c4655754b014bec998142cc39d75b51"}'></script>
  </body>
</html>

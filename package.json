{
  "name": "Grayslate",
  "version": "0.1.7",
  "description": "A fast scratchpad for code, data, and quick thinking.",
  "type": "module",
  "packageManager": "pnpm@10.32.1",
  "author": "Shriram Ethiraj",
  "homepage": "https://grayslate.app",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/shriram-ethiraj/grayslate.git"
  },
  "bugs": {
    "url": "https://github.com/shriram-ethiraj/grayslate/issues"
  },
  "keywords": [
    "scratchpad",
    "editor",
    "tauri",
    "svelte",
    "codemirror",
    "csv",
    "json",
    "developer-tools"
  ],
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "build:e2e": "vite build --mode e2e",
    "dev:website": "svelte-kit sync && pnpm --filter @grayslate/website dev",
    "build:website": "svelte-kit sync && pnpm --filter @grayslate/website build",
    "preview:website": "pnpm --filter @grayslate/website preview",
    "preview": "vite preview",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "release:version": "node scripts/release/set-version.mjs",
    "test:release-scripts": "node --test scripts/release/release-scripts.test.mjs",
    "test:package-repository": "node --test scripts/package-repository/package-repository.test.mjs",
    "tauri": "tauri",
    "e2e:build": "pnpm tauri build --no-bundle --features e2e --config src-tauri/tauri.e2e.conf.json",
    "e2e:check": "tsc --noEmit -p e2e/tsconfig.json",
    "e2e:test": "wdio run e2e/wdio.conf.ts",
    "e2e:ci": "xvfb-run -a sh -c 'openbox >/tmp/grayslate-openbox.log 2>&1 & sleep 1; exec pnpm run e2e:test'",
    "e2e:local": "pnpm run e2e:build && pnpm run e2e:test"
  },
  "license": "MIT",
  "dependencies": {
    "@codemirror/autocomplete": "^6.20.3",
    "@codemirror/commands": "^6.10.4",
    "@codemirror/lang-angular": "^0.1.4",
    "@codemirror/lang-cpp": "^6.0.3",
    "@codemirror/lang-css": "^6.3.1",
    "@codemirror/lang-go": "^6.0.1",
    "@codemirror/lang-html": "^6.4.11",
    "@codemirror/lang-java": "^6.0.2",
    "@codemirror/lang-javascript": "^6.2.5",
    "@codemirror/lang-jinja": "^6.0.1",
    "@codemirror/lang-json": "^6.0.2",
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/lang-php": "^6.0.2",
    "@codemirror/lang-python": "^6.2.1",
    "@codemirror/lang-rust": "^6.0.2",
    "@codemirror/lang-sass": "^6.0.2",
    "@codemirror/lang-sql": "^6.10.0",
    "@codemirror/lang-vue": "^0.1.3",
    "@codemirror/lang-xml": "^6.1.0",
    "@codemirror/lang-yaml": "^6.1.3",
    "@codemirror/language": "^6.12.4",
    "@codemirror/legacy-modes": "^6.5.3",
    "@codemirror/search": "^6.7.1",
    "@codemirror/state": "^6.7.1",
    "@codemirror/view": "^6.43.6",
    "@iconify-json/carbon": "^1.2.24",
    "@iconify-json/codicon": "^1.2.63",
    "@iconify-json/fluent": "^1.2.52",
    "@iconify-json/lucide": "^1.2.116",
    "@iconify-json/lucide-lab": "^1.2.3",
    "@iconify-json/material-symbols": "^1.2.83",
    "@iconify-json/mdi": "^1.2.3",
    "@iconify-json/pepicons-pop": "^1.2.3",
    "@iconify-json/ri": "^1.2.10",
    "@iconify-json/simple-icons": "^1.2.89",
    "@nextjournal/lang-clojure": "^1.0.0",
    "@replit/codemirror-lang-svelte": "^6.0.0",
    "@tailwindcss/typography": "^0.5.20",
    "@tanstack/hotkeys": "^0.8.0",
    "@tanstack/svelte-virtual": "^3.13.31",
    "@tauri-apps/api": "^2.11.1",
    "@tauri-apps/plugin-clipboard-manager": "^2.3.2",
    "@tauri-apps/plugin-dialog": "^2.7.1",
    "@tauri-apps/plugin-opener": "^2.5.4",
    "@tauri-apps/plugin-os": "~2.3.2",
    "@tauri-apps/plugin-window-state": "~2.4.1",
    "codemirror": "^6.0.2",
    "lodash-es": "^4.18.1"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "^24.0.0",
    "@internationalized/date": "^3.12.2",
    "@lezer/common": "^1.5.2",
    "@lezer/highlight": "^1.2.3",
    "@sveltejs/adapter-static": "^3.0.10",
    "@sveltejs/kit": "^2.69.2",
    "@sveltejs/vite-plugin-svelte": "6.2.4",
    "@tailwindcss/vite": "^4.3.2",
    "@tanstack/svelte-table": "9.0.0-alpha.10",
    "@tauri-apps/cli": "^2.11.4",
    "@wdio/cli": "^9.29.1",
    "@wdio/globals": "^9.29.1",
    "@wdio/local-runner": "^9.29.1",
    "@wdio/mocha-framework": "^9.29.1",
    "@wdio/spec-reporter": "^9.29.1",
    "@wdio/tauri-service": "1.1.0",
    "@wdio/tauri-plugin": "1.1.0",
    "@types/lodash-es": "^4.17.12",
    "bits-ui": "^2.18.1",
    "clsx": "^2.1.1",
    "mode-watcher": "^1.1.0",
    "paneforge": "^1.0.2",
    "svelte": "^5.56.4",
    "svelte-check": "^4.7.2",
    "svelte-sonner": "^1.1.1",
    "tailwind-merge": "^3.6.0",
    "tailwind-variants": "^3.2.2",
    "tailwindcss": "^4.3.2",
    "tw-animate-css": "^1.4.0",
    "typescript": "~6.0.3",
    "unplugin-icons": "^23.0.1",
    "vite": "6.4.3"
  }
}

app-id: app.grayslate.Grayslate
runtime: org.gnome.Platform
runtime-version: "50"
sdk: org.gnome.Sdk
command: Grayslate
finish-args:
  - --share=ipc
  - --socket=fallback-x11
  - --socket=wayland
  - --device=dri
  - --filesystem=xdg-documents/Grayslate:create
sdk-extensions:
  - org.freedesktop.Sdk.Extension.node22
  - org.freedesktop.Sdk.Extension.rust-stable
build-options:
  append-path: /usr/lib/sdk/node22/bin:/usr/lib/sdk/rust-stable/bin
  env:
    CARGO_HOME: /run/build/grayslate/cargo
    GRAYSLATE_UPDATE_POLICY: system-managed
modules:
  - name: grayslate
    buildsystem: simple
    build-commands:
      - corepack pnpm install --offline --frozen-lockfile
      - corepack pnpm tauri build --no-bundle
      - install -Dm755 target/release/Grayslate /app/bin/Grayslate
      - install -Dm644 packaging/linux/app.grayslate.Grayslate.desktop /app/share/applications/app.grayslate.Grayslate.desktop
      - install -Dm644 packaging/linux/app.grayslate.Grayslate.metainfo.xml /app/share/metainfo/app.grayslate.Grayslate.metainfo.xml
      - install -Dm644 src-tauri/icons/icon.png /app/share/icons/hicolor/512x512/apps/app.grayslate.Grayslate.png
    sources:
      - type: archive
        url: https://github.com/shriram-ethiraj/grayslate/releases/download/v@VERSION@/Grayslate-@VERSION@-source.tar.gz
        sha256: "@SOURCE_SHA256@"
      - generated-node-sources.json
      - generated-cargo-sources.json

pkgname=grayslate
pkgver=@VERSION@
pkgrel=1
pkgdesc="A fast scratchpad for code, data, and quick thinking"
arch=('x86_64')
url="https://grayslate.app"
license=('MIT')
depends=('gtk3' 'webkit2gtk-4.1')
makedepends=('cargo' 'nodejs' 'pnpm')
source=("$pkgname-$pkgver.tar.gz::https://github.com/shriram-ethiraj/grayslate/releases/download/v$pkgver/Grayslate-$pkgver-source.tar.gz")
sha256sums=('@SOURCE_SHA256@')

prepare() {
  cd "grayslate-$pkgver"
  pnpm install --frozen-lockfile
  cargo fetch --locked --manifest-path src-tauri/Cargo.toml
}

build() {
  cd "grayslate-$pkgver"
  GRAYSLATE_UPDATE_POLICY=system-managed pnpm tauri build --no-bundle
}

package() {
  cd "grayslate-$pkgver"
  install -Dm755 target/release/Grayslate "$pkgdir/usr/bin/Grayslate"
  install -Dm644 packaging/linux/app.grayslate.Grayslate.desktop "$pkgdir/usr/share/applications/app.grayslate.Grayslate.desktop"
  install -Dm644 packaging/linux/app.grayslate.Grayslate.metainfo.xml "$pkgdir/usr/share/metainfo/app.grayslate.Grayslate.metainfo.xml"
  install -Dm644 src-tauri/icons/icon.png "$pkgdir/usr/share/icons/hicolor/512x512/apps/app.grayslate.Grayslate.png"
  install -Dm644 LICENSE "$pkgdir/usr/share/licenses/$pkgname/LICENSE"
}
